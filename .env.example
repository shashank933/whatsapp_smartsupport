# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-flash-latest"

# DEEPSEEK_API_KEY: Optional fallback LLM provider.
# Get your key from https://platform.deepseek.com
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# APP_URL: The public URL where this app is hosted.
APP_URL="MY_APP_URL"

# HUBSPOT_ACCESS_TOKEN: Private app access token for HubSpot CRM integration.
# Used to auto-create/update contacts in HubSpot when a new customer messages via WhatsApp.
HUBSPOT_ACCESS_TOKEN="MY_HUBSPOT_PRIVATE_APP_TOKEN"

# WEBHOOK_VERIFY_TOKEN: Token used by Meta to verify the webhook endpoint.
# Must match the token configured in the WhatsApp Business app dashboard.
WEBHOOK_VERIFY_TOKEN="MY_WEBHOOK_VERIFY_TOKEN"
